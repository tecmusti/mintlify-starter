  "keyFeatures": [
    "AI image generation from product photos using predefined and custom scenes",
    "AI video generation with cinematic camera effects for product showcases",
    "Reusable scene templates with per-model and per-category targeting",
    "Credit-based billing with real-time balance checks and ledger history",
    "Full API key lifecycle management (create, list, revoke)",
    "Async generation with task polling via GET /status"
  ],
  "publicApiSurface": [
    "GET /healthz",
    "GET /wallet/balance",
    "POST /api-keys",
    "GET /api-keys",
    "DELETE /api-keys/{id}",
    "POST /generate (image)",
    "POST /generate (video)",
    "GET /status?taskId=...",
    "GET /generations",
    "GET /scenes",
    "GET /scenes/{scene_id}",
    "POST /scenes",
    "PUT /scenes/{scene_id}",
    "DELETE /scenes/{scene_id}"
  ]
