{
  "$schema": "https://mintlify.com/docs.json",
  "name": "estudjo",
  "theme": "luma",
  "colors": {
    "primary": "#ef7025",
    "light": "#eec9bc",
    "dark": "#4fa1ab"
  },
  "favicon": {
    "light": "/images/estudjo-icon-logo.png",
    "dark": "/images/estudjo-icon-logo.png"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/response-format",
              "concepts/scenes",
              "concepts/credits"
            ]
          },
          {
            "group": "How-To Guides",
            "pages": [
              "guides/generate-image",
              "guides/generate-video",
              "guides/poll-status",
              "guides/manage-scenes"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/limits",
              "reference/error-codes"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Health",
            "pages": [
              "api/health"
            ]
          },
          {
            "group": "API Keys",
            "pages": [
              "api/api-keys/create",
              "api/api-keys/list",
              "api/api-keys/revoke"
            ]
          },
          {
            "group": "Wallet",
            "pages": [
              "api/wallet/balance"
            ]
          },
          {
            "group": "Generations",
            "pages": [
              "api/generations/generate",
              "api/generations/status",
              "api/generations/history"
            ]
          },
          {
            "group": "Scenes",
            "pages": [
              "api/scenes/list",
              "api/scenes/get",
              "api/scenes/create",
              "api/scenes/update",
              "api/scenes/delete"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://www.estudjo.com"
    }
  },
  "logo": {
    "light": "/images/estudjo-logo.svg",
    "dark": "/images/estudjo-logo-white.svg"
  },
  "icons": {
    "library": "lucide"
  },
  "fonts": {
    "heading": {
      "family": "Geist"
    },
    "body": {
      "family": "Inter"
    }
  }
}
